---
/**
 * Team page (/team) — the people building Nuro. Group photo, then profiles
 * grouped as Founders / Team / Board, each with contact details. Phone
 * numbers shown in +46(0) international format.
 */
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/nav/Nav.astro";
import Footer from "@/components/footer/Footer.astro";
import Reveal from "@/components/motion/Reveal.astro";
import styles from "@/components/team/team.module.css";

export const prerender = true;

type Person = {
  name: string;
  role: string;
  phoneDisplay?: string;
  phoneHref?: string;
  email: string;
};

const GROUPS: { heading: string; people: Person[] }[] = [
  {
    heading: "Founders",
    people: [
      {
        name: "Sandra Hilltomt",
        role: "Founder & CEO",
        phoneDisplay: "+46(0)736 56 01 63",
        phoneHref: "+46736560163",
        email: "sandra@nuroai.dev",
      },
      {
        name: "Victor Wallander",
        role: "Co-Founder & CTO",
        phoneDisplay: "+46(0)730 35 25 06",
        phoneHref: "+46730352506",
        email: "victor@nuroai.dev",
      },
    ],
  },
  {
    heading: "Team",
    people: [
      {
        name: "Jonathan Olsen",
        role: "Head of Design",
        email: "jonathan@nuroai.dev",
      },
      {
        name: "Isabella Sällfors",
        role: "Founders Associate",
        email: "isabella@nuroai.dev",
      },
    ],
  },
  {
    heading: "Board",
    people: [
      {
        name: "Sead Kadric",
        role: "Board Member",
        phoneDisplay: "+46(0)708 79 51 17",
        phoneHref: "+46708795117",
        email: "sead@nuroai.dev",
      },
    ],
  },
];
---

<Layout
  title="Team — Nuro"
  description="Meet the team building Nuro — the founders, the team, and the board behind a mission to give every neurodivergent student the support they're entitled to."
>
  <Nav />
  <main>
    <section class={styles.section}>
      <div class={styles.container}>
        <Reveal as="span" eager class={styles.eyebrow}>Team</Reveal>
        <Reveal as="h1" eager delay={0.06} class={styles.heading}>
          The people building Nuro
        </Reveal>
        <Reveal as="p" eager delay={0.1} class={styles.intro}>
          Engineers, educators, and builders on one mission: make sure every
          neurodivergent student gets the support they&rsquo;re entitled to.
        </Reveal>

        <Reveal class={styles.photo} delay={0.14}>
          <img
            src="/team/founders.jpg"
            alt="Sandra Hilltomt and Victor Wallander, Nuro's founders"
            width="1000"
            height="1500"
            loading="lazy"
          />
        </Reveal>

        {
          GROUPS.map((group) => (
            <div class={styles.group}>
              <Reveal as="h2" class={styles.groupHeading}>
                {group.heading}
              </Reveal>
              <div class={styles.people}>
                {group.people.map((p) => (
                  <Reveal class={styles.person}>
                    <span class={styles.personName}>{p.name}</span>
                    <span class={styles.personRole}>{p.role}</span>
                    <div class={styles.contact}>
                      {p.phoneDisplay && (
                        <a
                          class={styles.contactLink}
                          href={`tel:${p.phoneHref}`}
                        >
                          {p.phoneDisplay}
                        </a>
                      )}
                      <a class={styles.contactLink} href={`mailto:${p.email}`}>
                        {p.email}
                      </a>
                    </div>
                  </Reveal>
                ))}
              </div>
            </div>
          ))
        }

        <Reveal as="p" class={styles.hiring}>
          We&rsquo;re growing. <a href="/career">See open roles →</a>
        </Reveal>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
