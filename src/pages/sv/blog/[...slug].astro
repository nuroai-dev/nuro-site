---
/**
 * Single Swedish blog post (/sv/blog/<slug>) — renders a Markdown post from the
 * blogSv collection with prose styling and BlogPosting JSON-LD. Mirrors
 * src/pages/blog/[...slug].astro; only the collection, locale, date format and
 * back link differ.
 */
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/nav/Nav.astro";
import Footer from "@/components/footer/Footer.astro";
import Reveal from "@/components/motion/Reveal.astro";
import RelatedPosts from "@/components/blog/RelatedPosts.astro";
import PostCta from "@/components/blog/PostCta.astro";
import styles from "@/components/blog/blog.module.css";
import { buildTagIndex, tagSlug, tagLabel } from "@/lib/blog-tags";

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection("blogSv", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Clickable tag chips: only tags that have their own topic-hub page (used by
// 2+ posts) qualify, so every chip links somewhere real.
const qualifying = new Set(
  buildTagIndex(await getCollection("blogSv", ({ data }) => !data.draft)).map(
    (g) => g.slug,
  ),
);
const tagSlugs = [...new Set(post.data.tags.map(tagSlug))].filter((s) =>
  qualifying.has(s),
);

const SITE_URL = "https://nuroai.dev";
const url = `${SITE_URL}/sv/blog/${post.id}`;
const fmt = (d: Date) =>
  d.toLocaleDateString("sv-SE", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });

const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  inLanguage: "sv-SE",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: { "@type": "Organization", name: post.data.author },
  publisher: { "@id": `${SITE_URL}/#organization` },
  mainEntityOfPage: url,
  image: `${SITE_URL}/og/blog-sv/${post.id}.png`,
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Hem", item: `${SITE_URL}/sv/` },
    { "@type": "ListItem", position: 2, name: "Blogg", item: `${SITE_URL}/sv/blog` },
    { "@type": "ListItem", position: 3, name: post.data.title, item: url },
  ],
};
---

<Layout title={`${post.data.title} | Nuro`} description={post.data.description} ogType="article" publishedTime={post.data.pubDate.toISOString()} author={post.data.author} ogImage={`${SITE_URL}/og/blog-sv/${post.id}.png`} ogImageAlt={post.data.title}>
  <Nav />
  <main id="main-content" tabindex="-1">
    <section class={styles.section}>
      <div class={`${styles.container} ${styles.article}`}>
        <a class={styles.backLink} href="/sv/blog">← Blogg</a>
        <Reveal as="h1" eager class={styles.heading}>{post.data.title}</Reveal>
        <Reveal as="p" eager delay={0.06} class={styles.articleMeta}>
          {fmt(post.data.pubDate)} · {post.data.author}
        </Reveal>
        {tagSlugs.length > 0 && (
          <div class={styles.tags}>
            {tagSlugs.map((s) => (
              <a class={styles.tagChip} href={`/sv/blog/tag/${s}`}>{tagLabel(s)}</a>
            ))}
          </div>
        )}
        <article class={styles.prose}>
          <Content />
        </article>
      </div>
    </section>
    <PostCta />
    <RelatedPosts post={post} collection="blogSv" />
  </main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
</Layout>
