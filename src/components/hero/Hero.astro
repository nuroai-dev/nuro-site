---
/**
 * Hero — SPEC §4 "Hero (min 100vh, aurora background)".
 *
 * All copy is in the SSR HTML. Below the copy sits a framed product
 * screenshot of the Nuro dashboard.
 *
 * Entrances stagger per SPEC §5.1 (H1 0, lead +0.08s, CTA +0.16s, media
 * +0.24s) and are all `eager` (SPEC §6 N-14): above-fold content starts its
 * entrance at first paint via CSS so the LCP is never delayed by JS.
 */
import Aurora from "@/components/motion/Aurora.astro";
import Reveal from "@/components/motion/Reveal.astro";
import styles from "./hero.module.css";
import { getLang } from "@/i18n/ui";

const lang = getLang(Astro.url);
const t = {
  en: {
    title: "Let's help schools stop breaking the law",
    tagPre: "The missing tool for ",
    tagHi: "neurodivergent",
    tagPost: " students.",
    cta: "Join waitlist",
    alt: "The Nuro student dashboard, a calm daily view with focus blocks and quests.",
  },
  sv: {
    title: "Hjälp skolor att sluta bryta mot lagen",
    tagPre: "Det saknade verktyget för ",
    tagHi: "neurodivergenta",
    tagPost: " elever.",
    cta: "Gå med i väntelistan",
    alt: "Nuros elevvy, en lugn daglig översikt med fokuspass och uppdrag.",
  },
}[lang];
---

<section class={styles.hero} id="hero">
  <Aurora variant="hero" />
  <div class={styles.inner}>
    <Reveal as="h1" eager class={styles.title}>
      {t.title}
    </Reveal>
    <Reveal as="p" eager delay={0.08} class={styles.tagline}>
      {t.tagPre}<span class="holo-text">{t.tagHi}</span>{t.tagPost}
    </Reveal>
    <Reveal eager delay={0.16} class={styles.ctaRow}>
      <a href="#waitlist" class={`${styles.cta} focusable`}>
        {t.cta}
        <svg
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14M13 6l6 6-6 6"></path>
        </svg>
      </a>
    </Reveal>
    <Reveal eager delay={0.24}>
      <div class={styles.media}>
        <img
          class={styles.heroImage}
          src="/nuro-hero.webp"
          fetchpriority="high"
          alt={t.alt}
          width="2400"
          height="1600"
        />
      </div>
    </Reveal>
  </div>
</section>
