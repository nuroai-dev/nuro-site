---
/**
 * BreadcrumbSchema.astro emits BreadcrumbList JSON-LD (plus an optional
 * WebPage-subtype node) for a top-level sub-page, so search and answer engines
 * get a Home to Page trail and a typed page entity. Language-aware via
 * Astro.url: the Home crumb points at / for English and /sv for Swedish, and
 * the current crumb uses this page's own path.
 */
import { getLang } from "@/i18n/ui";

interface Props {
  name: string;
  pageType?: string;
}
const { name, pageType } = Astro.props;

const SITE_URL = "https://nuroai.dev";
const lang = getLang(Astro.url);
const inLanguage = lang === "sv" ? "sv-SE" : "en-US";
const homeUrl = lang === "sv" ? `${SITE_URL}/sv` : SITE_URL;
const homeName = lang === "sv" ? "Hem" : "Home";
const currentUrl = new URL(Astro.url.pathname, SITE_URL).href;
const breadcrumbId = `${currentUrl}#breadcrumb`;

const breadcrumb = {
  "@type": "BreadcrumbList",
  "@id": breadcrumbId,
  itemListElement: [
    { "@type": "ListItem", position: 1, name: homeName, item: homeUrl },
    { "@type": "ListItem", position: 2, name, item: currentUrl },
  ],
};

const graph = pageType
  ? [
      {
        "@type": pageType,
        "@id": `${currentUrl}#webpage`,
        url: currentUrl,
        name,
        isPartOf: { "@id": `${SITE_URL}/#website` },
        inLanguage,
        breadcrumb: { "@id": breadcrumbId },
      },
      breadcrumb,
    ]
  : [breadcrumb];

const data = { "@context": "https://schema.org", "@graph": graph };
---
<script type="application/ld+json" set:html={JSON.stringify(data)} />
