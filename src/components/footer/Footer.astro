---
/**
 * Footer — light-mode, multi-column (structure adapted from the Pit footer,
 * recolored to the site's light surface).
 *
 * Layout: brand lockup + four link columns (Product / Company / Social /
 * Legal), then the giant outlined "Nuro" wordmark spanning the container,
 * with the credits bar (© / Designed in Sweden / Back to top) floating over
 * its lower edge behind a backdrop blur.
 *
 * Product links mirror the page sections; Company/Legal point at "#"
 * placeholders until those pages exist.
 */
import Reveal from "@/components/motion/Reveal.astro";
import ContactDrawer from "@/components/contact/ContactDrawer.tsx";
import styles from "./footer.module.css";
import { getLang, localizePath, switchLangPath } from "@/i18n/ui";

const LINKEDIN_URL = "https://www.linkedin.com/company/nuroaidev/";
const INSTAGRAM_URL = "https://www.instagram.com/nuroai.dev/";

const lang = getLang(Astro.url);
const lp = (href: string) => localizePath(href, lang);
const otherLang = lang === "sv" ? "en" : "sv";
const switchHref = switchLangPath(Astro.url.pathname, otherLang);

const T = {
  en: {
    product: "Product",
    company: "Company",
    social: "Social",
    legal: "Legal",
    problem: "Problem",
    businessCase: "Business case",
    solution: "Solution",
    joinWaitlist: "Join waitlist",
    about: "About",
    team: "Team",
    blog: "Blog",
    press: "Press",
    career: "Career",
    contact: "Contact",
    privacy: "Privacy",
    terms: "Terms",
    designed: "Designed in Sweden",
    backToTop: "Back to top",
    switchTo: "English",
  },
  sv: {
    product: "Produkt",
    company: "Företag",
    social: "Socialt",
    legal: "Juridik",
    problem: "Problem",
    businessCase: "Affärscase",
    solution: "Lösning",
    joinWaitlist: "Gå med i väntelistan",
    about: "Om oss",
    team: "Team",
    blog: "Blogg",
    press: "Press",
    career: "Karriär",
    contact: "Kontakt",
    privacy: "Integritet",
    terms: "Villkor",
    designed: "Designad i Sverige",
    backToTop: "Tillbaka till toppen",
    switchTo: "Svenska",
  },
}[lang];

type Icon = "linkedin" | "instagram";
type Col = {
  head: string;
  links: {
    label: string;
    href: string;
    external?: boolean;
    icon?: Icon;
    drawer?: boolean;
  }[];
};

const COLUMNS: Col[] = [
  {
    head: T.product,
    links: [
      { label: T.problem, href: lp("/#problem") },
      { label: T.businessCase, href: lp("/#business-case") },
      { label: T.solution, href: lp("/#features") },
      { label: T.joinWaitlist, href: lp("/#waitlist") },
    ],
  },
  {
    head: T.company,
    links: [
      { label: T.about, href: lp("/about") },
      { label: T.team, href: lp("/team") },
      { label: T.blog, href: lp("/blog") },
      { label: T.press, href: lp("/press") },
      { label: T.career, href: lp("/career") },
      { label: T.contact, href: "#contact", drawer: true },
    ],
  },
  {
    head: T.social,
    links: [
      { label: "LinkedIn", href: LINKEDIN_URL, external: true, icon: "linkedin" },
      { label: "Instagram", href: INSTAGRAM_URL, external: true, icon: "instagram" },
    ],
  },
  {
    head: T.legal,
    links: [
      { label: T.privacy, href: lp("/privacy") },
      { label: T.terms, href: lp("/terms") },
    ],
  },
];
---

<footer class={styles.footer}>
  <Reveal class={styles.container}>
    <div class={styles.grid}>
      <div class={styles.brandCol}>
        <a href={lp("/#hero")} class={styles.brand} aria-label={`Nuro — ${T.backToTop}`}>
          <img
            src="/brand/nuro-lockup.svg"
            alt="Nuro"
            width="124"
            height="36"
            class={styles.brandLockup}
          />
        </a>
      </div>

      {
        COLUMNS.map((col) => (
          <nav class={styles.col} aria-label={col.head}>
            <h3 class={styles.colHead}>{col.head}</h3>
            <ul class={styles.colList}>
              {col.links.map((link) => (
                <li>
                  <a
                    class={styles.colLink}
                    href={link.href}
                    data-contact-trigger={link.drawer ? "" : undefined}
                    {...(link.external
                      ? { target: "_blank", rel: "noopener noreferrer" }
                      : {})}
                  >
                    {link.icon === "linkedin" && (
                      <svg
                        class={styles.socialIcon}
                        width="15"
                        height="15"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45z" />
                      </svg>
                    )}
                    {link.icon === "instagram" && (
                      <svg
                        class={styles.socialIcon}
                        width="15"
                        height="15"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <rect x="2.5" y="2.5" width="19" height="19" rx="5.2" />
                        <circle cx="12" cy="12" r="4.4" />
                        <circle cx="17.3" cy="6.7" r="1.15" fill="currentColor" stroke="none" />
                      </svg>
                    )}
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>
  </Reveal>

  {/* Giant outlined wordmark spanning the container; the credits bar floats
      over its lower edge behind a backdrop blur. */}
  <div class={styles.bigWrap}>
    <div class={styles.bigInner}>
      <img
        src="/brand/nuro-outline.svg"
        alt=""
        width="1092"
        height="279"
        class={styles.bigLogo}
      />
    </div>

    <div class={styles.creditsBar}>
      <p class={styles.copyright}>© Nuro, 2026</p>

      <p class={styles.swedish}>
        <svg
          width="16"
          height="12"
          viewBox="0 0 16 12"
          xmlns="http://www.w3.org/2000/svg"
          class={styles.flag}
          aria-hidden="true"
        >
          <rect width="16" height="12" fill="#006AA7"></rect>
          <rect x="5" width="2" height="12" fill="#FECC02"></rect>
          <rect y="5" width="16" height="2" fill="#FECC02"></rect>
        </svg>
        {T.designed}
      </p>

      <a href={switchHref} hreflang={otherLang} class={styles.backToTop}>
        {T.switchTo}
      </a>

      <a href={lp("/#hero")} class={styles.backToTop}>{T.backToTop} ↑</a>
    </div>
  </div>

  {/* Vaul contact drawer — opens when the "Contact" link (data-contact-trigger)
      is clicked. The island renders nothing inline (Vaul portals on open), so
      it hydrates on idle rather than on visibility (no box to observe). */}
  <ContactDrawer client:load />
</footer>
