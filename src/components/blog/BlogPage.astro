---
/**
 * Blog index content, locale-aware (English at /blog, Swedish at /sv/blog).
 * Rendered by both src/pages/blog/index.astro and src/pages/sv/blog/index.astro
 * so there is one source of truth.
 *
 * The page chrome is translated, and so are the posts: /blog lists the English
 * `blog` collection, /sv/blog lists the Swedish `blogSv` collection (same slugs,
 * translated bodies). The cards link to the matching locale's post URL.
 */
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/nav/Nav.astro";
import Footer from "@/components/footer/Footer.astro";
import Reveal from "@/components/motion/Reveal.astro";
import BlogCard from "@/components/blog/BlogCard.astro";
import styles from "@/components/blog/blog.module.css";
import { getLang } from "@/i18n/ui";

const lang = getLang(Astro.url);
const t = {
  en: {
    title: "Blog — Nuro",
    description:
      "Notes on neurodiversity in education — what the research says, what the law requires, and what actually helps teachers, students, and parents.",
    eyebrow: "Blog",
    heading: "Notes on inclusive education",
    intro:
      "What the research says, what the law requires, and what actually helps neurodivergent students — for the teachers, students, and parents living it every day.",
    empty: "No posts yet — the first one is on its way.",
  },
  sv: {
    title: "Blogg — Nuro",
    description:
      "Tankar om neurodiversitet i skolan, vad forskningen säger, vad lagen kräver och vad som faktiskt hjälper lärare, elever och föräldrar.",
    eyebrow: "Blogg",
    heading: "Tankar om en inkluderande skola",
    intro:
      "Vad forskningen säger, vad lagen kräver och vad som faktiskt hjälper neurodivergenta elever, för lärarna, eleverna och föräldrarna som lever med det varje dag.",
    empty: "Inga inlägg än, det första är på väg.",
  },
}[lang];

export const prerender = true;

const posts = (
  await getCollection(lang === "sv" ? "blogSv" : "blog", ({ data }) => !data.draft)
).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout title={t.title} description={t.description}>
  <Nav />
  <main>
    <section class={styles.section}>
      <div class={styles.container}>
        <Reveal as="span" eager class={styles.eyebrow}>{t.eyebrow}</Reveal>
        <Reveal as="h1" eager delay={0.06} class={styles.heading}>
          {t.heading}
        </Reveal>
        <Reveal as="p" eager delay={0.1} class={styles.intro}>
          {t.intro}
        </Reveal>

        {
          posts.length > 0 ? (
            <div class={styles.grid}>
              {posts.map((post, i) => (
                <Reveal delay={Math.min(i, 6) * 0.05}>
                  <BlogCard post={post} />
                </Reveal>
              ))}
            </div>
          ) : (
            <p class={styles.empty}>{t.empty}</p>
          )
        }
      </div>
    </section>
  </main>
  <Footer />
</Layout>
