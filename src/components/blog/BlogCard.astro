---
/**
 * Blog card — one post, styled to match the Press cards (cover image or
 * branded fallback, meta line, title, description, read link). The whole card
 * links to the post.
 */
import type { CollectionEntry } from "astro:content";
import styles from "./blog.module.css";
import { getLang } from "@/i18n/ui";
import { tagSlug, tagLabel } from "@/lib/blog-tags";

interface Props {
  post: CollectionEntry<"blog"> | CollectionEntry<"blogSv">;
}

const { post } = Astro.props;

// Card chrome and post link follow the page locale: /sv cards link to the
// Swedish post body at /sv/blog/<slug>, English cards to /blog/<slug>.
const lang = getLang(Astro.url);
const readMore = lang === "sv" ? "Läs artikeln" : "Read article";
const href = lang === "sv" ? `/sv/blog/${post.id}` : `/blog/${post.id}`;

const dateLabel = new Intl.DateTimeFormat(lang === "sv" ? "sv-SE" : "en-GB", {
  day: "numeric",
  month: "short",
  year: "numeric",
}).format(post.data.pubDate);

// Fallback panel label — the post's most specific tag (Title Case). Every
// post carries the generic "neurodiversity" tag, so prefer the first tag that
// isn't that, to keep the cards visually distinct (Skollagen / Teacher
// shortage / School absence …). Falls back to the first tag, then "Nuro".
const tag =
  post.data.tags.find((t) => t.toLowerCase() !== "neurodiversity") ??
  post.data.tags[0];
const fallbackLabel = tag ? tagLabel(tagSlug(tag)) : "Nuro";
---

<a class={styles.card} href={href}>
  <div class={styles.media}>
    {
      post.data.heroImage ? (
        <img
          class={styles.image}
          src={post.data.heroImage}
          alt=""
          loading="lazy"
        />
      ) : (
        <div class={styles.mediaFallback} aria-hidden="true">
          <span class={styles.fallbackOutlet}>{fallbackLabel}</span>
        </div>
      )
    }
  </div>

  <div class={styles.body}>
    <div class={styles.meta}>
      <span class={styles.outlet}>{post.data.author}</span>
      <span class={styles.dot} aria-hidden="true">·</span>
      <time class={styles.date} datetime={post.data.pubDate.toISOString()}>
        {dateLabel}
      </time>
    </div>

    <h3 class={styles.title}>{post.data.title}</h3>
    <p class={styles.tldr}>{post.data.description}</p>

    <span class={styles.readMore}>
      {readMore}
      <svg
        class={styles.extIcon}
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M5 12h14M13 6l6 6-6 6"></path>
      </svg>
    </span>
  </div>
</a>
