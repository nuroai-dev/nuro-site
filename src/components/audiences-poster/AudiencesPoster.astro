---
/**
 * Audiences poster section — editorial three-panel exploration of the three
 * audiences (Students / Teachers / Parents). Small eyebrow, large display
 * headline, atmospheric gradient filling each panel, product chip anchored
 * bottom. All visuals are CSS gradients — no images. Panels reveal with a
 * stagger and lift slightly on hover.
 */
import Reveal from "@/components/motion/Reveal.astro";
import styles from "./audiences-poster.module.css";
import { getLang } from "@/i18n/ui";

type Panel = {
  eyebrow: string;
  headline: string;
  bullets: readonly string[];
  chip: string;
};

const lang = getLang(Astro.url);
const t = {
  en: {
    headingPre: "One platform.",
    headingMuted: "Three experiences.",
    cta: "Join waitlist",
    closing:
      "By automating support, Nuro doesn't just save time, it prevents the lifetime societal cost of student dropouts due to lack of bandwidth.",
    panels: [
      {
        eyebrow: "For Students",
        headline: "Learning that works with your brain.",
        bullets: ["24/7 personalized support", "Zero overwhelm", "Research-backed structure"],
        chip: "▶ Start first block",
      },
      {
        eyebrow: "For Teachers",
        headline: "Every student seen. No extra hours.",
        bullets: ["Automated adaptation", "Saves 40+ hours per month", "Easier documentation and follow-up"],
        chip: "Focus score 72",
      },
      {
        eyebrow: "For Parents",
        headline: "Know how your child is really doing.",
        bullets: ["Real-time progress feed", "Auto-compliance documentation", "Direct connection with teachers"],
        chip: "93% of focus blocks completed",
      },
    ] as Panel[],
  },
  sv: {
    headingPre: "En plattform.",
    headingMuted: "Tre upplevelser.",
    cta: "Gå med i väntelistan",
    closing:
      "Genom att automatisera stödet sparar Nuro inte bara tid — det förhindrar den livslånga samhällskostnaden för elever som hoppar av på grund av brist på resurser.",
    panels: [
      {
        eyebrow: "För elever",
        headline: "Lärande som funkar med din hjärna.",
        bullets: ["Personligt stöd dygnet runt", "Noll överväldigande", "Forskningsbaserad struktur"],
        chip: "▶ Starta första passet",
      },
      {
        eyebrow: "För lärare",
        headline: "Varje elev sedd. Inga extra timmar.",
        bullets: ["Automatisk anpassning", "Sparar 40+ timmar i månaden", "Enklare dokumentation och uppföljning"],
        chip: "Fokuspoäng 72",
      },
      {
        eyebrow: "För föräldrar",
        headline: "Vet hur ditt barn egentligen mår.",
        bullets: ["Realtidsflöde över framsteg", "Automatisk dokumentation för regelefterlevnad", "Direktkontakt med lärare"],
        chip: "93% av fokuspassen avklarade",
      },
    ] as Panel[],
  },
}[lang];

const TONE_CLASSES = [styles.toneLight, styles.toneIndigo, styles.tonePink];
const PANELS = t.panels;
---

<section id="audience" class={styles.section}>
  <div class={styles.container}>
    <Reveal class={styles.header}>
      <h2 class={styles.heading}>
        {t.headingPre}
        <br />
        <span class={styles.headingMuted}>{t.headingMuted}</span>
      </h2>
      <a class={styles.cta} href="#waitlist">
        {t.cta} <span aria-hidden="true">→</span>
      </a>
    </Reveal>

    <div class={styles.grid}>
      {
        PANELS.map((panel, i) => (
          <Reveal
            class={`${styles.panel} ${TONE_CLASSES[i]}`}
            delay={i * 0.08}
          >
            <div class={styles.panelTop}>
              <div class={styles.eyebrow}>{panel.eyebrow}</div>
              <h3 class={styles.headline}>{panel.headline}</h3>
            </div>

            <div class={styles.panelBottom}>
              <ul class={styles.bullets}>
                {panel.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
              <span class={styles.chip}>{panel.chip}</span>
            </div>
          </Reveal>
        ))
      }
    </div>

    <Reveal as="p" class={styles.closing} delay={0.24}>
      {t.closing}
    </Reveal>
  </div>
</section>
