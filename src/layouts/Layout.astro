---
/**
 * Root layout — the <html> shell (SPEC §4 Meta, ported from the Next
 * layout.tsx). Self-hosts the three font families via @fontsource (IBM Plex
 * Sans for display, Inter for body, JetBrains Mono for eyebrows/meta), imports
 * the global stylesheet once, sets metadata/OG, and loads the motion runtime.
 *
 * The tiny inline head script marks JS as available before paint so the reveal
 * motion can gate its hidden initial state on [data-js]; no-JS users never see
 * the hidden state and content stays sharp and visible.
 */
// Variable fonts — one woff2 per family per subset (weight axis only) instead
// of 11 static weight files × 7 subsets. The browser fetches just the latin /
// latin-ext subsets it needs at runtime via unicode-range.
import "@fontsource-variable/ibm-plex-sans/wght.css";
import "@fontsource-variable/inter/wght.css";
import "@fontsource-variable/jetbrains-mono/wght.css";
import "@/styles/globals.css";

// Hashed URLs for the two above-the-fold families' latin weight files, so we
// can <link rel=preload> them — discovered with the HTML instead of only after
// the CSS parses. Kills the fallback→webfont swap flash on the hero. (Same
// source files the @font-face rules reference, so Vite dedupes to one asset.)
import plexLatinHref from
  "@fontsource-variable/ibm-plex-sans/files/ibm-plex-sans-latin-wght-normal.woff2?url";
import interLatinHref from
  "@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url";

const SITE_URL = "https://nuroai.dev";
const DEFAULT_TITLE = "Nuro — Inclusive Education for Swedish Schools";
const DEFAULT_DESCRIPTION =
  "Nuro helps Swedish schools support neurodiverse students with ADHD, Autism, and Dyslexia. AI-powered lesson adaptation that meets Skollagen requirements.";

interface Props {
  title?: string;
  description?: string;
}

const { title = DEFAULT_TITLE, description = DEFAULT_DESCRIPTION } =
  Astro.props;
const TITLE = title;
const DESCRIPTION = description;
const OG_IMAGE = `${SITE_URL}/og.png`;
const CANONICAL = new URL(Astro.url.pathname, SITE_URL).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="canonical" href={CANONICAL} />

    {/* Preload the above-the-fold webfonts so the hero never swaps from the
        system fallback (which would reflow the H1 mid blur-in). */}
    <link
      rel="preload"
      href={plexLatinHref}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href={interLatinHref}
      as="font"
      type="font/woff2"
      crossorigin
    />

    <title>{TITLE}</title>
    <meta name="description" content={DESCRIPTION} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={CANONICAL} />
    <meta property="og:site_name" content="Nuro" />
    <meta property="og:title" content={TITLE} />
    <meta property="og:description" content={DESCRIPTION} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Nuro — The missing tool for neurodivergent students."
    />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={TITLE} />
    <meta name="twitter:description" content={DESCRIPTION} />
    <meta name="twitter:image" content={OG_IMAGE} />

    {/* Runs before paint: marks JS as available so the reveal motion gates
        its hidden initial state on [data-js]. */}
    <script is:inline>
      document.documentElement.dataset.js = "1";
    </script>
  </head>
  <body>
    <slot />
    <script>
      import "@/scripts/motion";
    </script>
  </body>
</html>
