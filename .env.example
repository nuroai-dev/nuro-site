# Contact form email delivery (src/lib/contact/save-contact-entry.ts).
# Set these on the deploy platform's environment.

# Resend API key — required for the contact form to actually send.
# Without it, submissions are logged server-side instead of emailed.
RESEND_API_KEY=

# Recipient + sender. The CONTACT_FROM domain must be verified in Resend.
# Defaults: hello@nuroai.dev / "Nuro <hello@nuroai.dev>"
CONTACT_TO=hello@nuroai.dev
CONTACT_FROM=Nuro <hello@nuroai.dev>
